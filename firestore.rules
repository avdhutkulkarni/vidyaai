rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    match /usage/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
      match /daily/{date} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    match /doubt_history/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
      match /doubts/{doubtId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    match /cache/{document=**} {
      allow read: if false;
      allow write: if false;
    }

    match /photos2023/{document=**} {
      allow read: if false;
      allow write: if false;
    }

    match /hard_questions/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /admins/{uid} {
      allow read: if false;
      allow write: if false;
    }

    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}